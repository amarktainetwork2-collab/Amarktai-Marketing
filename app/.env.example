# ============================================================
# Amarktai Marketing – Frontend Environment Variables
# ============================================================
# Copy this file to .env.local for local development, or set
# these as build ARGs / environment variables in Docker.

# Backend API URL (leave empty to use the Nginx proxy at /api)
# For local development without Docker, set to http://localhost:8000
VITE_API_URL=

# Clerk Authentication (get from https://clerk.com)
# Leave empty to run in demo mode without authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# App metadata (used for display purposes only — no secrets here)
VITE_APP_NAME=Amarktai Marketing
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=production
