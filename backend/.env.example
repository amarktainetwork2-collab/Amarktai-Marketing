# ============================================
# Amarktai Marketing - Environment Variables
# ============================================

# Application
APP_NAME="Amarktai Marketing"
APP_VERSION="1.0.0"
DEBUG=false
FRONTEND_URL="https://marketing.amarktai.com"

# Admin email — this account always has unlimited access at zero cost
ADMIN_EMAIL="amarktainetwork@gmail.com"

# ============================================
# AMARKTAI NETWORK INTEGRATION
# ============================================
# Per-app identity (set these for every deployed instance)
APP_ID="amarktai-marketing"
APP_SLUG="amarktai-marketing"
APP_ENVIRONMENT="production"   # production | staging | development

# Outbound connection to the Amarktai Network main dashboard.
# AMARKTAI_INTEGRATION_TOKEN must be generated in the Amarktai Network admin
# under Apps → Register App → Generate Token.  Keep it server-side ONLY.
AMARKTAI_DASHBOARD_URL="https://dashboard.amarktai.com"
AMARKTAI_INTEGRATION_TOKEN=""   # generated per-app token — NEVER expose to frontend
AMARKTAI_INTEGRATION_ENABLED=false   # set to true once token is configured

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amarktai"

# Redis (for Celery and caching)
REDIS_URL="redis://localhost:6379"

# CORS Origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# Clerk Authentication
CLERK_SECRET_KEY="sk_test_..."
CLERK_PUBLISHABLE_KEY="pk_test_..."
# Clerk webhook signing secret (from Clerk Dashboard → Webhooks → Signing Secret)
CLERK_WEBHOOK_SECRET="whsec_..."

# Encryption Key (generate with: openssl rand -base64 32)
ENCRYPTION_KEY="your-encryption-key-here-change-in-production"

# ============================================
# AI CONTENT GENERATION — REQUIRED FOR LAUNCH
# ============================================
# Primary: Qwen (Alibaba Cloud DashScope) — high quality, low cost
# Get key at: https://dashscope.aliyun.com/
QWEN_API_KEY=""
QWEN_MODEL="Qwen/Qwen2.5-72B-Instruct"

# Fallback: Hugging Face Inference API (free tier available)
# Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=""

# ============================================
# AI CONTENT GENERATION — OPTIONAL INTERNAL FALLBACK
# ============================================
# OpenAI — optional polish pass only (not required for launch)
OPENAI_API_KEY=""

# ============================================
# IMAGE GENERATION API KEYS (OPTIONAL / DEFERRED)
# ============================================

# Leonardo.ai (Premium quality)
LEONARDO_API_KEY=""

# Midjourney (via API)
MIDJOURNEY_API_KEY=""

# Stability AI
STABILITY_API_KEY=""

# Replicate (Cheap alternative)
REPLICATE_API_TOKEN=""

# fal.ai (Fast generation)
FAL_AI_KEY=""

# SiliconFlow (Free tier)
SILICONFLOW_API_KEY=""

# ============================================
# VIDEO GENERATION API KEYS
# ============================================

# Runway ML (Premium video generation)
RUNWAY_API_KEY="..."

# HeyGen (AI avatars)
HEYGEN_API_KEY="..."

# Synthesia
SYNTHESIA_API_KEY="..."

# ============================================
# AUDIO/Voice API KEYS
# ============================================

# ElevenLabs (Best quality voice)
ELEVENLABS_API_KEY="..."

# Coqui TTS (FREE - Open source)
COQUI_API_KEY="..."

# Play.ht
PLAYHT_API_KEY="..."

# ============================================
# SOCIAL PLATFORM API KEYS (OAuth2)
# ============================================

# YouTube (Google Cloud Console)
YOUTUBE_CLIENT_ID="..."
YOUTUBE_CLIENT_SECRET="..."
YOUTUBE_API_KEY="..."

# TikTok (TikTok for Developers)
TIKTOK_CLIENT_KEY="..."
TikTok_CLIENT_SECRET="..."
TIKTOK_APP_ID="..."

# Meta (Facebook Developers)
META_APP_ID="..."
META_APP_SECRET="..."
INSTAGRAM_CLIENT_ID="${META_APP_ID}"
INSTAGRAM_CLIENT_SECRET="${META_APP_SECRET}"
FACEBOOK_CLIENT_ID="${META_APP_ID}"
FACEBOOK_CLIENT_SECRET="${META_APP_SECRET}"

# Twitter/X (Twitter Developer Portal)
TWITTER_CLIENT_ID="..."
TWITTER_CLIENT_SECRET="..."
TWITTER_API_KEY="..."
TWITTER_API_SECRET="..."
TWITTER_BEARER_TOKEN="..."

# LinkedIn (LinkedIn Developers)
LINKEDIN_CLIENT_ID="..."
LINKEDIN_CLIENT_SECRET="..."

# Pinterest (Pinterest Developers)
PINTEREST_CLIENT_ID="..."
PINTEREST_CLIENT_SECRET="..."

# Reddit (reddit.com/prefs/apps)
REDDIT_CLIENT_ID="..."
REDDIT_CLIENT_SECRET="..."
REDDIT_USER_AGENT="AmarktaiBot/1.0"

# Bluesky / AT Protocol (bsky.social app password)
BLUESKY_IDENTIFIER="yourhandle.bsky.social"
BLUESKY_APP_PASSWORD="xxxx-xxxx-xxxx-xxxx"

# Telegram (BotFather token + channel)
TELEGRAM_BOT_TOKEN="123456789:AAxxxxx"
TELEGRAM_CHANNEL_ID="@yourchannel"

# Snapchat (Snap Business Manager)
SNAPCHAT_CLIENT_ID="..."
SNAPCHAT_CLIENT_SECRET="..."

# ============================================
# TREND DATA SOURCES
# ============================================

# Google Trends (via SerpAPI)
SERPAPI_KEY="..."
GOOGLE_TRENDS_API_KEY="..."

# Reddit (for trend analysis)
REDDIT_CLIENT_ID="..."
REDDIT_CLIENT_SECRET="..."
REDDIT_USER_AGENT="AmarktaiBot/1.0"

# News APIs
NEWSAPI_KEY="..."
GNEWS_API_KEY="..."

# ============================================
# WEB SCRAPING
# ============================================

# Firecrawl (for web app crawling)
FIRECRAWL_API_KEY="..."

# ScrapingBee
SCRAPINGBEE_API_KEY="..."

# ============================================
# PAYMENTS
# ============================================

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_FREE="price_..."
STRIPE_PRICE_ID_PRO="price_..."
STRIPE_PRICE_ID_BUSINESS="price_..."
STRIPE_PRICE_ID_ENTERPRISE="price_..."

# ============================================
# EMAIL
# ============================================

# Resend
RESEND_API_KEY="re_..."
FROM_EMAIL="noreply@amarktai.com"

# Brevo (Sendinblue) - Alternative
BREVO_API_KEY="..."

# ============================================
# STORAGE
# ============================================

# Supabase
SUPABASE_URL="https://...supabase.co"
SUPABASE_KEY="eyJ..."
SUPABASE_BUCKET="amarktai-media"

# AWS S3 (Alternative)
AWS_ACCESS_KEY_ID="..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="amarktai-media"
AWS_REGION="us-east-1"

# ============================================
# MONITORING
# ============================================

# Sentry
SENTRY_DSN="https://...@sentry.io/..."

# ============================================
# FEATURE FLAGS
# ============================================

ENABLE_AUTO_POST=false
ENABLE_AUTO_REPLY=false
ENABLE_AB_TESTING=true
ENABLE_VIRAL_PREDICTION=true
ENABLE_COST_TRACKING=true

# ============================================
# RATE LIMITS
# ============================================

MAX_CONTENT_PER_DAY=10
MAX_ENGAGEMENT_REPLIES_PER_DAY=50
MAX_MEDIA_GENERATIONS_PER_DAY=20
